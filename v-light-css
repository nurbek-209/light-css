/* responsive */
.l-tablet {
    display: grid;
    grid-template-columns: repeat(4, auto);
}

.l-tablet-2 {
    display: flex;
    flex-direction: column;
}

.l-tablet-text-small {
    display: block;
}

@media only screen and (max-width:768px) {
    .l-tablet {
        grid-template-columns: repeat(2, auto);
    }

    .l-tablet-2 {
        display: grid;
        grid-template-columns: repeat(2, auto);
        justify-content: center;
        align-items: center;
        gap: 10px;
    }

    .l-tablet-text-small {
        font-size: 12px;
    }
