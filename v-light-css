/* transitions && animations */
.l-ein {
    transition: ease-in;
}

.l-eino {
    transition: ease-in-out;
}

.l-eout {
    transition: ease-out;
}

.l-superfast {
    transition: 0.3s;
}

.l-fast {
    transition: 0.5s;
}

.l-normally {
    transition: 0.7s;
}

.l-slow {
    transition: 1.2s;
}

/* /* trasitions && animations */
.l-bottom-trs:hover {
    transform: translateY(-10px);
}
.l-bottom-trs-2:hover
{
    transform: translateY(-5px);
}
.l-shadow:hover {
    box-shadow: 2px 8px 8px 2px gray;
}

.l-scale:hover {
    transform: scale(1.08);
}

.l-scale-2:hover {
    transform: scale(1.12);
}

.l-animation-1 {
    animation: 1.2s ease-out 1 animation-1;
}

@keyframes animation-1 {
    0% {
        transform: translateY(-200px) scale(0);
    }

    50% {
        transform: translateY(-100px);
    }

    100% {
        transform: translateY(0px) scale(1);
    }

}

.l-animation-2 {
    animation: 1.2s ease-out 1 animation-2;
}

@keyframes animation-2 {
    0% {
        transform: translateX(-200px);
    }

    100% {
        transform: translateX(0px);
    }
}
.l-animation-3
{
    animation: 1.2s ease-in-out  animation-3 1;
}
@keyframes animation-3 {
    0%
    {
        transform: scale(0.3)translateX(-400px);
    }
    100%
    {
        transform: scale(1);
    }
}
/* template-columns */
