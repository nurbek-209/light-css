/* transitions && animations */
.l-ein
{
    transition: ease-in;
}
.l-eino 
{
    transition: ease-in-out;
}
.l-eout
{
    transition: ease-out;
}
.l-superfast
{
    transition: 0.3s;
}
.l-fast 
{
    transition: 0.5s;
}
.l-normally
{
    transition: 0.7s;
}
.l-slow
{
    transition: 1.2s;
}
/* Light CSS ga qo'shish */
.l-bottom:hover {
    transform: translateY(-10px);
}
.l-shadow:hover
{
    box-shadow: 2px 8px 8px 2px gray;
}
.l-scale:hover 
{
    transform: scale(1.08);
}
.l-scale-2:hover
{
    transform: scale(1.12);
}
/* template-columns */
.l-tmpc-1
{
    grid-template-columns: repeat(1,auto);
}
