/* 1. DISPLAY SYSTEMS */
.l-flex {
    display: flex;
}

.l-grid {
    display: grid;
}

.l-none {
    display: none;
}

/* 3. JUSTIFY CONTENT */
.l-justify-center {
    justify-content: center;
}
.l-radius
{
    border-radius: 5px;
}
.l-radius-2
{
    border-radius: 10px;
}
.l-radius-3
{
    border-radius: 20px;
}
.l-radius-4
{
    border-radius: 40px;
}
.l-shadow-1
{
    box-shadow: 1px 3px 3px 1px gray;
}
.l-shadow-2
{
    box-shadow: 2px 8px 8px 2px gray;
}
.l-shadow-3
{
    box-shadow: 4px 12px 12px 4px gray;
}
.l-shadow-super
{
    box-shadow: 10px 20px 20px 10px gray;
}
.l-justify-between {
    justify-content: space-between;
}

.l-justify-start {
    justify-content: flex-start;
}

.l-justify-end {
    justify-content: flex-end;
}

.l-justify-around {
    justify-content: space-around;
}

.l-justify-evenly {
    justify-content: space-evenly;
}

